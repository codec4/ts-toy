{
  "name": "ts-toy",
  "version": "1.0.0",
  "description": "Some experiments with ts lang",
  "main": "src/app.ts",
  "scripts": {
    "build": "rimraf ./build && tsc",
    "start:dev": "pnpm nodemon",
    "start": "npm run build && node build/app.js",
    "fix": "run-s fix:*",
    "fix:prettier": "prettier \"src/**/*.ts\" --write",
    "clean": "run-s \"rm build\"",
    "rm": "rm -rf"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run fix"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codec4/ts-toy.git"
  },
  "author": "O.Step",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codec4/ts-toy/issues"
  },
  "homepage": "https://github.com/codec4/ts-toy#readme",
  "devDependencies": {
    "@types/node": "20.3.1",
    "husky": "8.0.3",
    "npm-run-all": "4.1.5",
    "prettier": "2.8.8",
    "tap": "^16.3.4",
    "typescript": "5.1.3"
  },
  "dependencies": {
    "nodemon": "^2.0.22",
    "rimraf": "^5.0.1",
    "rxjs": "7.8.1",
    "ts-node": "^10.9.1"
  },
  "private": true
}
