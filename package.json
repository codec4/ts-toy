{
  "name": "ts-toy",
  "version": "1.0.0",
  "description": "Some experiments with ts lang",
  "main": "index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:dev": "run-s clean build && run-p \"build -- --w\" serve",
    "serve": "nodemon --delay 500ms ./build/src/app.js",
    "fix": "run-s fix:*",
    "fix:prettier": "prettier \"src/**/*.ts\" --write",
    "clean": "run-s \"rm build\"",
    "rm": "rm -rf"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run fix"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codec4/ts-toy.git"
  },
  "author": "O.Step",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codec4/ts-toy/issues"
  },
  "homepage": "https://github.com/codec4/ts-toy#readme",
  "devDependencies": {
    "@types/node": "14.14.41",
    "@types/node-fetch": "2.5.10",
    "chai": "4.3.4",
    "husky": "6.0.0",
    "mocha": "8.3.2",
    "nodemon": "2.0.7",
    "npm-run-all": "4.1.5",
    "prettier": "2.2.1",
    "typescript": "4.2.4"
  },
  "dependencies": {
    "node-fetch": "2.6.1",
    "rxjs": "7.1.0"
  }
}
